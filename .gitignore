# Build outputs
dist-electron/
release/

# Compiled outputs that should never live next to .ts source
src/**/*.js
src/**/*.js.map
!src/renderer/*.js  # renderer.js is intentionally bundled by tsc to its own dir
src/preload/*.js
src/preload/*.js.map

# Generated reports / slide decks (test exports against the bundled NMEF invoice)
out/

# Customer invoice and source material — never commit cost data.
# The smoke script and integration tests pick up any *.xlsx in the
# project root (or RECKON_TEST_INVOICE), so dropping a real export
# here is supported but it must never be tracked.
*.xlsx
*.csv
*.pdf
~$*
transcript.txt

# Test fixtures — synthetic and real customer data both stay local.
# The scan + invoice generators in tools/ rebuild these on demand.
test-fixtures/

# Ad-hoc screenshots from QA / Playwright runs.
*.png
.playwright-mcp/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Misc
*.log
.npm/
